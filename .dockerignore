# .dockerignore — bc-sql
# Excluye archivos innecesarios del contexto de build de Docker

# Control de versiones
.git/
.gitignore
.gitmessage

# Editor y configuración de IDE
.vscode/
.github/

# Documentación del proyecto (no necesaria en el contenedor)
README.md
README_EN.md
LICENSE
CONTRIBUTING.md
CODE_OF_CONDUCT.md
SECURITY.md
_docs/
_assets/

# Contenido del bootcamp (el contenedor solo necesita recibir
# los archivos .sql que se montan o pasan por stdin)
bootcamp/

# Archivos de sistema
.DS_Store
Thumbs.db
*.log

# Scripts de pausa/restauración (no van en el contenedor)
_scripts/pause.sh
_scripts/resume.sh
_scripts/restore.sh
